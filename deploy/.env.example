# Poller settings
ARTIFACT_SOURCE=s3://your-artifacts-bucket
# For local dev, point at the ETL output directory (contains manifests/ and tiles/)
# ARTIFACT_SOURCE=/absolute/path/to/etl/out

RESTART_ENABLED=true

# Base directory for tileserver data (tiles/, manifests/, static/, public/)
TILESERVER_DIR=/opt/weather-map/tileserver
