[Unit]
Description=Weather Map Docker Compose
After=network-online.target docker.service cloud-final.service
Wants=network-online.target cloud-final.service

[Service]
Type=oneshot
WorkingDirectory=/opt/weather-map
ExecStart=/usr/local/lib/docker/cli-plugins/docker-compose -f deploy/compose.prod.yml up -d
ExecStop=/usr/local/lib/docker/cli-plugins/docker-compose -f deploy/compose.prod.yml down
RemainAfterExit=yes

[Install]
WantedBy=multi-user.target
