  "overlayLayers": [
    {
      "id": "precipitation_type",
      "style": "precipitation-type-pattern",
      "source": {
        "artifactId": "precip_type_surface",
        "bands": [
          {
            "id": "snow_frac"
          },
          {
            "id": "mix_frac"
          }
        ]
