          },
          {
            "id": "middle"
          },
          {
            "id": "high"
          }
        ]
      },
      "displayProfile": "cloud-layers"
    },
    {
      "id": "cloud_cover",
      "groupId": "clouds_visibility",
      "source": {
        "artifactId": "tcdc",
        "bands": [
          {
            "id": "value"
          }
        ]
      },
      "displayProfile": "cloud-cover"
