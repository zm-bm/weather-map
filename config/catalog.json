{
  "catalogVersion": "forecast-catalog-v1",
  "rasterLayerGroups": [
    {
      "id": "temperature",
      "label": "Temperature",
      "rasterLayerIds": [
        "temperature",
        "apparent_temperature"
      ]
    },
    {
      "id": "humidity",
      "label": "Humidity",
      "rasterLayerIds": [
        "dew_point",
        "relative_humidity"
      ]
    },
    {
      "id": "wind_pressure",
      "label": "Wind & Pressure",
      "rasterLayerIds": [
        "wind_gust",
        "wind_speed",
        "air_pressure"
      ]
    },
    {
      "id": "precipitation",
      "label": "Precipitation",
      "rasterLayerIds": [
        "precipitation_rate",
        "accumulated_precipitation"
      ]
    },
    {
      "id": "clouds_visibility",
      "label": "Clouds",
      "rasterLayerIds": [
        "cloud_layers",
        "cloud_cover"
      ]
    },
    {
      "id": "radar_storms",
      "label": "Radar",
      "rasterLayerIds": [
        "observed_radar_composite_reflectivity",
        "composite_reflectivity"
      ]
    }
  ],
  "rasterLayers": [
    {
      "id": "temperature",
      "groupId": "temperature",
      "source": {
