{
  "version": 1,
  "workload": {
    "forecast_hour_start": 0,
    "forecast_hour_end": 36,
    "variables": [
      "tmp_surface",
      "rh_surface",
      "prmsl_surface",
      "tcdc",
      "prate_surface"
    ]
  },
  "nomads": {
    "base_url": "https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_0p25.pl",
    "vars_levels": {
      "all_var": "on",
      "lev_2_m_above_ground": "on",
      "lev_10_m_above_ground": "on",
      "lev_surface": "on",
      "lev_mean_sea_level": "on",
      "lev_entire_atmosphere": "on"
    },
    "rate_limit_seconds": 2
  },
  "scalar_variables": {
    "tmp_surface": {
      "parameter": "tmp",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "TMP",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": -45,
      "scale_max": 50,
      "units": "C",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "tmp_surface_i16_v1",
        "dtype": "int16",
        "byte_order": "little",
        "scale": 0.01,
        "offset": 0,
        "nodata": -32768
      }
    },
    "aptmp_surface": {
      "parameter": "aptmp",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "APTMP",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": -45,
      "scale_max": 50,
      "units": "C",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "aptmp_surface_i16_v1",
        "dtype": "int16",
        "byte_order": "little",
        "scale": 0.01,
        "offset": 0,
        "nodata": -32768
      }
    },
    "rh_surface": {
      "parameter": "rh",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "RH",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": 0,
      "scale_max": 100,
      "units": "%",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "rh_surface_i16_v1",
        "dtype": "int16",
        "byte_order": "little",
        "scale": 0.01,
        "offset": 0,
        "nodata": -32768
      }
    },
    "prmsl_surface": {
      "parameter": "prmsl",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "PRMSL",
        "GRIB_SHORT_NAME": "0-MSL"
      },
      "scale_min": 98000,
      "scale_max": 103500,
      "units": "Pa",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "prmsl_surface_i16_v1",
        "dtype": "int16",
        "byte_order": "little",
        "scale": 0.1,
        "offset": 100500,
        "nodata": -32768
      }
    },
    "tcdc": {
      "parameter": "tcdc",
      "level": "entire atmosphere",
      "grib_match": {
        "GRIB_ELEMENT": "TCDC",
        "GRIB_SHORT_NAME": "0-EATM"
      },
      "scale_min": 0,
      "scale_max": 100,
      "units": "%",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "tcdc_i16_v1",
        "dtype": "int16",
        "byte_order": "little",
        "scale": 0.01,
        "offset": 0,
        "nodata": -32768
      }
    },
    "prate_surface": {
      "parameter": "prate",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "PRATE",
        "GRIB_SHORT_NAME": "0-SFC"
      },
      "scale_min": 0,
      "scale_max": 0.008333333,
      "units": "kg/m^2/s",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "prate_surface_i16_v1",
        "dtype": "int16",
        "byte_order": "little",
        "scale": 3e-07,
        "offset": 0,
        "nodata": -32768
      }
    }
  },
  "vector_variables": {
    "wind10m_uv": {
      "label": "10m Wind U/V",
      "units": "m/s",
      "u_grib_match": {
        "GRIB_ELEMENT": "UGRD",
        "GRIB_SHORT_NAME": "10-HTGL"
      },
      "v_grib_match": {
        "GRIB_ELEMENT": "VGRD",
        "GRIB_SHORT_NAME": "10-HTGL"
      }
    }
  }
}
