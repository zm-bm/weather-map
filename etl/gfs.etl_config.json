{
  "version": 1,
  "workload": {
    "forecast_hour_start": 0,
    "forecast_hour_end": 24,
    "variables": [
      "tmp_surface",
      "aptmp_surface",
      "gust_surface",
      "dewpoint_surface",
      "rh_surface",
      "prmsl_surface",
      "tcdc",
      "prate_surface"
    ]
  },
  "nomads": {
    "base_url": "https://nomads.ncep.noaa.gov/cgi-bin/filter_gfs_0p25.pl",
    "vars_levels": {
      "all_var": "on",
      "lev_2_m_above_ground": "on",
      "lev_10_m_above_ground": "on",
      "lev_surface": "on",
      "lev_mean_sea_level": "on",
      "lev_entire_atmosphere": "on"
    },
    "rate_limit_seconds": 2
  },
  "scalar_variable_groups": [
    {
      "id": "temperature",
      "label": "Temperature",
      "default_variable": "tmp_surface",
      "variables": [
        "tmp_surface",
        "aptmp_surface"
      ]
    },
    {
      "id": "moisture",
      "label": "Moisture",
      "default_variable": "rh_surface",
      "variables": [
        "rh_surface",
        "dewpoint_surface"
      ]
    },
    {
      "id": "wind",
      "label": "Wind",
      "default_variable": "gust_surface",
      "variables": [
        "gust_surface"
      ]
    },
    {
      "id": "precipitation",
      "label": "Precipitation",
      "default_variable": "prate_surface",
      "variables": [
        "prate_surface"
      ]
    },
    {
      "id": "clouds",
      "label": "Clouds",
      "default_variable": "tcdc",
      "variables": [
        "tcdc"
      ]
    },
    {
      "id": "pressure",
      "label": "Pressure",
      "default_variable": "prmsl_surface",
      "variables": [
        "prmsl_surface"
      ]
    }
  ],
  "scalar_variables": {
    "tmp_surface": {
      "parameter": "tmp",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "TMP",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": -35,
      "scale_max": 50,
      "units": "C",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "tmp_surface_i8_temp_c_piecewise_v1",
        "format": "scalar-i8-temp-c-piecewise-v1",
        "dtype": "int8",
        "byte_order": "none",
        "nodata": -128
      }
    },
    "aptmp_surface": {
      "parameter": "aptmp",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "APTMP",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": -35,
      "scale_max": 50,
      "units": "C",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "tmp_surface_i8_temp_c_piecewise_v1",
        "format": "scalar-i8-temp-c-piecewise-v1",
        "dtype": "int8",
        "byte_order": "none",
        "nodata": -128
      }
    },
    "rh_surface": {
      "parameter": "rh",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "RH",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": 0,
      "scale_max": 100,
      "units": "%",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "rh_surface_i8_1pct_v1",
        "dtype": "int8",
        "byte_order": "none",
        "scale": 1,
        "offset": 50,
        "nodata": -128
      }
    },
    "gust_surface": {
      "parameter": "gust",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "GUST",
        "GRIB_SHORT_NAME": "0-SFC"
      },
      "scale_min": 0,
      "scale_max": 60,
      "units": "m/s",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "gust_surface_i8_1ms_v1",
        "dtype": "int8",
        "byte_order": "none",
        "scale": 0.5,
        "offset": 63.5,
        "nodata": -128
      }
    },
    "dewpoint_surface": {
      "parameter": "dpt",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "DPT",
        "GRIB_SHORT_NAME": "2-HTGL"
      },
      "scale_min": -60,
      "scale_max": 40,
      "units": "C",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "dewpoint_surface_i8_0p5c_v1",
        "dtype": "int8",
        "byte_order": "none",
        "scale": 0.5,
        "offset": 0,
        "nodata": -128
      }
    },
    "prmsl_surface": {
      "parameter": "prmsl",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "PRMSL",
        "GRIB_SHORT_NAME": "0-MSL"
      },
      "scale_min": 98000,
      "scale_max": 103500,
      "units": "Pa",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "prmsl_surface_i8_25pa_v1",
        "dtype": "int8",
        "byte_order": "none",
        "scale": 25,
        "offset": 100500,
        "nodata": -128
      }
    },
    "tcdc": {
      "parameter": "tcdc",
      "level": "entire atmosphere",
      "grib_match": {
        "GRIB_ELEMENT": "TCDC",
        "GRIB_SHORT_NAME": "0-EATM"
      },
      "scale_min": 0,
      "scale_max": 100,
      "units": "%",
      "scalar_source_transform": "identity",
      "scalar_encoding": {
        "encoding_id": "tcdc_i8_0p5pct_v1",
        "dtype": "int8",
        "byte_order": "none",
        "scale": 1,
        "offset": 50,
        "nodata": -128
      }
    },
    "prate_surface": {
      "parameter": "prate",
      "level": "surface",
      "grib_match": {
        "GRIB_ELEMENT": "PRATE",
        "GRIB_SHORT_NAME": "0-SFC"
      },
      "scale_min": 0,
      "scale_max": 30,
      "units": "mm/hr",
      "scalar_source_transform": "kg_m2_s_to_mm_hr",
      "scalar_encoding": {
        "encoding_id": "prate_surface_i8_0p15mmhr_v1",
        "dtype": "int8",
        "byte_order": "none",
        "scale": 0.15,
        "offset": 19.05,
        "nodata": -128
      }
    }
  },
  "vector_variables": {
    "wind10m_uv": {
      "label": "10m Wind U/V",
      "units": "m/s",
      "u_grib_match": {
        "GRIB_ELEMENT": "UGRD",
        "GRIB_SHORT_NAME": "10-HTGL"
      },
      "v_grib_match": {
        "GRIB_ELEMENT": "VGRD",
        "GRIB_SHORT_NAME": "10-HTGL"
      }
    }
  }
}
