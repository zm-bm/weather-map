{
  "version": 8,
  "glyphs": "/font/{fontstack}/{range}",
  "sources": {
    "openmaptiles": {
      "type": "vector",
      "url": "https://tiles.openfreemap.org/planet",
      "promoteId": {
        "place": "name"
      }
    }
  },
  "sprite": "https://tiles.openfreemap.org/sprites/ofm_f384/ofm",
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgb(244, 241, 235)"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["!=", ["get", "brunnel"], "tunnel"]
      ],
      "paint": {
        "fill-antialias": true,
        "fill-color": "rgb(208, 216, 220)",
        "fill-opacity": 0.05
      }
    },
    {
      "id": "coastline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
        ["==", ["get", "class"], "ocean"],
        ["!=", ["get", "brunnel"], "tunnel"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(8, 12, 20)",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.5,
          4, 0.9,
          5.99, 1
        ]
      }
    },
    {
