      },
      "paint": {
        "line-color": "rgb(18, 22, 30)",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.55,
          4, 0.65,
          5.99, 0.72
        ]
      }
    },
    {
      "id": "river_outline",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "water",
      "filter": [
        "all",
        ["match", ["geometry-type"], ["MultiPolygon", "Polygon"], true, false],
