        "line-blur": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.18,
          8, 0.1,
          12, 0.04,
          20, 0
        ]
      }
    },
    {
      "id": "road_major",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "transportation",
      "minzoom": 5,
      "filter": [
        "all",
        ["match", ["geometry-type"], ["LineString", "MultiLineString"], true, false],
        ["match", ["get", "class"], ["motorway", "trunk"], true, false]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(48, 52, 58)",
        "line-opacity": 0.2,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.78,
          5.5, 0.84,
          6, 0.92
        ]
      }
    },
    {
      "id": "boundary_4",
      "type": "line",
      "source": "openmaptiles",
      "source-layer": "boundary",
      "minzoom": 3.5,
      "filter": [
        "all",
        ["match", ["get", "admin_level"], [3, 4], true, false],
        ["!=", ["get", "maritime"], 1],
        ["!=", ["get", "disputed"], 1],
        ["!", ["has", "claimed_by"]]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(8, 12, 18)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.48,
          7, 0.56,
          11, 0.62,
          20, 0.68
