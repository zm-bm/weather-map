{
  "version": 8,
  "sources": {
    "basemap": {
      "type": "vector",
      "url": "pmtiles://example.invalid/basemap.pmtiles",
      "attribution": "<a href=\"https://github.com/protomaps/basemaps\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>",
      "maxzoom": 6
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgb(203, 211, 216)"
      }
    },
    {
      "id": "earth_mask",
      "type": "fill",
      "source": "basemap",
      "source-layer": "earth",
      "paint": {
        "fill-color": "rgb(240, 237, 230)"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "==",
        "$type",
        "Polygon"
      ],
      "paint": {
        "fill-antialias": true,
        "fill-color": "rgb(190, 205, 211)",
        "fill-opacity": 0.24
      }
    },
    {
      "id": "landcover_context",
      "type": "fill",
      "source": "basemap",
      "source-layer": "landcover",
      "minzoom": 3,
      "maxzoom": 9,
      "paint": {
        "fill-antialias": false,
        "fill-color": [
          "match", ["get", "kind"],
          ["forest", "grassland", "scrub"], "rgb(139, 171, 127)",
          ["farmland", "barren"], "rgb(202, 185, 137)",
          ["glacier"], "rgb(210, 226, 229)",
          "rgb(185, 198, 160)"
        ],
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.08,
          6, 0.14,
          8, 0.18
        ]
      }
    },
    {
      "id": "landuse_context",
      "type": "fill",
      "source": "basemap",
      "source-layer": "landuse",
      "minzoom": 4,
      "maxzoom": 12,
      "filter": [
        "in",
        "kind",
        "residential",
        "commercial",
        "industrial",
        "retail"
      ],
      "paint": {
        "fill-antialias": false,
        "fill-color": "rgb(118, 132, 112)",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.12,
          6, 0.22,
          8, 0.30
        ]
      }
    },
    {
      "id": "coastline_shadow",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "ocean",
        "sea"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(24, 29, 36)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.18,
          6, 0.32
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 2.0,
          6, 3.6
        ],
        "line-blur": 1.2
      }
    },
    {
      "id": "lake_fill",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "any",
        ["in", "kind", "lake", "sea"],
        ["all", ["==", "kind", "water"], ["==", "kind_detail", "lake"]]
      ],
      "paint": {
        "fill-antialias": true,
        "fill-color": "rgb(88, 148, 158)",
        "fill-opacity": 0.28
      }
    },
    {
      "id": "coastline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "ocean"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(29, 33, 36)",
        "line-opacity": 0.88,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.75,
          4, 1.3,
          6, 1.55
        ]
      }
    },
    {
      "id": "lake_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "any",
        ["==", "kind", "lake"],
        ["all", ["==", "kind", "water"], ["==", "kind_detail", "lake"]]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(32, 57, 62)",
        "line-opacity": 0.58,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.7,
          4, 0.9,
          6, 1.1
        ]
      }
    },
    {
      "id": "river_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "river",
        "stream"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(42, 110, 122)",
        "line-opacity": 0.68,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.5,
          4, 0.78,
          6, 1.05
        ],
        "line-blur": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.08,
          8, 0.04,
          12, 0,
          20, 0
        ]
      }
    },
    {
      "id": "road_major",
      "type": "line",
      "source": "basemap",
      "source-layer": "roads",
      "minzoom": 4,
      "filter": [
        "all",
        ["!has", "is_tunnel"],
        ["!has", "is_bridge"],
        ["in", "kind", "major_road", "highway"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(51, 48, 43)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.18,
          5, 0.30,
          7, 0.46,
          10, 0.60
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.45,
          5, 0.75,
          6, 1.05,
          10, 1.65
        ]
      }
    },
    {
      "id": "boundary_4",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "minzoom": 3.5,
      "filter": [
        ">",
        "kind_detail",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(54, 57, 52)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.36,
          7, 0.48,
          11, 0.56,
          20, 0.62
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.7,
          7, 1.0,
          11, 1.25,
          20, 1.45
        ]
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "filter": [
        "<=",
        "kind_detail",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(39, 42, 40)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.34,
          4, 0.52,
          10, 0.66
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.82,
          5, 0.98,
          12, 1.9,
          20, 2.15
        ]
      }
    }
  ]
}
