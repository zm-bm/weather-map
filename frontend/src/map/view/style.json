{
  "version": 8,
  "sources": {
    "basemap": {
      "type": "vector",
      "url": "pmtiles://example.invalid/basemap.pmtiles",
      "attribution": "<a href=\"https://github.com/protomaps/basemaps\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>",
      "maxzoom": 9
    },
    "satellite_basemap": {
      "type": "raster",
      "tiles": [
        "https://gibs.earthdata.nasa.gov/wmts/epsg3857/best/BlueMarble_NextGeneration/default/default/GoogleMapsCompatible_Level8/{z}/{y}/{x}.jpeg"
      ],
      "tileSize": 256,
      "minzoom": 0,
      "maxzoom": 8,
      "bounds": [-180, -85.051129, 180, 85.051129],
      "attribution": "<a href=\"https://www.earthdata.nasa.gov/engage/open-data-services-software/earthdata-developer-portal/gibs-api\">NASA GIBS</a> / ESDIS"
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgb(203, 211, 216)"
      }
    },
    {
      "id": "earth_mask",
      "type": "fill",
      "source": "basemap",
      "source-layer": "earth",
      "paint": {
        "fill-color": "rgb(240, 237, 230)"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "==",
        "$type",
        "Polygon"
      ],
      "paint": {
        "fill-antialias": true,
        "fill-color": "rgb(190, 205, 211)",
        "fill-opacity": 0.24
      }
    },
    {
      "id": "satellite_basemap",
      "type": "raster",
      "source": "satellite_basemap",
      "layout": {
        "visibility": "none"
      },
      "paint": {
        "raster-opacity": 0,
        "raster-brightness-min": 0,
        "raster-brightness-max": 1,
        "raster-saturation": 0,
        "raster-contrast": 0,
        "raster-fade-duration": 0
      }
    },
    {
      "id": "urban_area_context",
      "type": "fill",
      "source": "basemap",
      "source-layer": "landcover",
      "minzoom": 4,
      "maxzoom": 8.75,
      "filter": [
        "==",
        "kind",
        "urban_area"
      ],
      "paint": {
        "fill-antialias": false,
        "fill-color": "rgb(88, 100, 89)",
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.04,
          5.7, 0.075,
          6.25, 0.10,
          7.25, 0.12,
          8.75, 0.08
        ],
        "fill-outline-color": "rgba(42, 52, 45, 0.28)"
      }
    },
    {
      "id": "city_context",
      "type": "fill",
      "source": "basemap",
      "source-layer": "landuse",
      "minzoom": 5.75,
      "maxzoom": 15,
      "filter": [
        "in",
        "kind",
        "residential",
        "commercial",
        "industrial"
      ],
      "paint": {
        "fill-antialias": false,
        "fill-color": [
          "match", ["get", "kind"],
          ["commercial", "industrial"], "rgb(66, 74, 66)",
          "rgb(71, 84, 73)"
        ],
        "fill-opacity": [
          "interpolate", ["linear"], ["zoom"],
          5.75, 0.00,
          6.25, 0.06,
          7.25, 0.10,
          8.25, 0.135,
          9, 0.16,
          10, 0.17
        ],
        "fill-outline-color": "rgba(40, 50, 43, 0.24)"
      }
    },
    {
      "id": "urban_area_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "landcover",
      "minzoom": 4,
      "maxzoom": 8.75,
      "filter": [
        "==",
        "kind",
        "urban_area"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(39, 48, 43)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.08,
          5.7, 0.13,
          6.25, 0.17,
          7.25, 0.22,
          8.75, 0.12
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.35,
          6.25, 0.55,
          7.25, 0.68,
          8.75, 0.45
        ],
        "line-blur": 0.18
      }
    },
    {
      "id": "coastline_shadow",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "ocean",
        "sea"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(24, 29, 36)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.18,
          6, 0.32
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 2.0,
          6, 3.6
        ],
        "line-blur": 1.2
      }
    },
    {
      "id": "lake_fill",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "any",
        ["in", "kind", "lake", "sea"],
        ["all", ["==", "kind", "water"], ["==", "kind_detail", "lake"]]
      ],
      "paint": {
        "fill-antialias": true,
        "fill-color": "rgb(88, 148, 158)",
        "fill-opacity": 0.28
      }
    },
    {
      "id": "coastline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "ocean"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(29, 33, 36)",
        "line-opacity": 0.88,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.75,
          4, 1.3,
          6, 1.55
        ]
      }
    },
    {
      "id": "lake_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "any",
        ["==", "kind", "lake"],
        ["all", ["==", "kind", "water"], ["==", "kind_detail", "lake"]]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(32, 57, 62)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.54,
          5.7, 0.52,
          6.25, 0.48,
          8.25, 0.43,
          10, 0.40
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.65,
          4, 0.86,
          6, 1.05,
          10, 1.16
        ]
      }
    },
    {
      "id": "river_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "river",
        "stream"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(42, 110, 122)",
        "line-opacity": 0.68,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.42,
          4, 0.68,
          6, 0.92,
          8, 1.04,
          10, 1.12
        ],
        "line-blur": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.08,
          8, 0.04,
          12, 0,
          20, 0
        ]
      }
    },
    {
      "id": "road_major",
      "type": "line",
      "source": "basemap",
      "source-layer": "roads",
      "minzoom": 4,
      "filter": [
        "all",
        ["!has", "is_tunnel"],
        ["!has", "is_bridge"],
        ["in", "kind", "major_road", "highway"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(70, 66, 57)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.07,
          5, 0.11,
          6.25, 0.15,
          7.25, 0.18,
          8.25, 0.21,
          9, 0.24,
          10, 0.26
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.28,
          5, 0.42,
          6.25, 0.56,
          7.25, 0.66,
          8.25, 0.74,
          9, 0.82,
          10, 0.9
        ]
      }
    },
    {
      "id": "boundary_4",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "minzoom": 3.5,
      "filter": [
        ">",
        "kind_detail",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(47, 50, 47)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.34,
          7, 0.46,
          10, 0.52,
          20, 0.58
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.62,
          7, 0.88,
          11, 1.12,
          20, 1.34
        ]
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "filter": [
        "<=",
        "kind_detail",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(39, 42, 40)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.30,
          4, 0.46,
          10, 0.58
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.76,
          5, 0.92,
          12, 1.72,
          20, 1.98
        ]
      }
    }
  ]
}
