        ],
        "text-halo-blur": 0.7,
        "text-halo-color": [
          "case",
          ["boolean", ["feature-state", "hover"], false],
          "rgba(16, 24, 44, 1)",
          "rgba(27, 35, 60, 0.96)"
        ],
        "text-halo-width": [
          "case",
