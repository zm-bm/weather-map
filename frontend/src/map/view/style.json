{
  "version": 8,
  "glyphs": "/glyphs/{fontstack}/{range}.pbf",
  "sources": {
    "basemap": {
      "type": "vector",
      "url": "pmtiles://example.invalid/basemap.pmtiles",
      "attribution": "<a href=\"https://github.com/protomaps/basemaps\">Protomaps</a> © <a href=\"https://openstreetmap.org\">OpenStreetMap</a>",
      "maxzoom": 5
    }
  },
  "layers": [
    {
      "id": "background",
      "type": "background",
      "paint": {
        "background-color": "rgb(244, 241, 235)"
      }
    },
    {
      "id": "water",
      "type": "fill",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "==",
        "$type",
        "Polygon"
      ],
      "paint": {
        "fill-antialias": true,
        "fill-color": "rgb(208, 216, 220)",
        "fill-opacity": 0.05
      }
    },
    {
      "id": "coastline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "ocean"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(8, 12, 20)",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.5,
          4, 0.9,
          6, 1
        ]
      }
    },
    {
      "id": "lake_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "lake"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(18, 22, 30)",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.55,
          4, 0.65,
          6, 0.72
        ]
      }
    },
    {
      "id": "river_outline",
      "type": "line",
      "source": "basemap",
      "source-layer": "water",
      "filter": [
        "in",
        "kind",
        "river",
        "stream"
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(18, 22, 30)",
        "line-opacity": 1,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          1, 0.24,
          4, 0.32,
          6, 0.38
        ],
        "line-blur": [
          "interpolate", ["linear"], ["zoom"],
          6, 0.18,
          8, 0.1,
          12, 0.04,
          20, 0
        ]
      }
    },
    {
      "id": "road_major",
      "type": "line",
      "source": "basemap",
      "source-layer": "roads",
      "minzoom": 5,
      "filter": [
        "all",
        ["!has", "is_tunnel"],
        ["!has", "is_bridge"],
        ["in", "kind", "major_road", "highway"]
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(48, 52, 58)",
        "line-opacity": 0.2,
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          5, 0.78,
          5.5, 0.84,
          6, 0.92
        ]
      }
    },
    {
      "id": "boundary_4",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "minzoom": 3.5,
      "filter": [
        ">",
        "kind_detail",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(8, 12, 18)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          4, 0.48,
          7, 0.56,
          11, 0.62,
          20, 0.68
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.6,
          7, 0.8,
          11, 0.84,
          20, 1.16
        ]
      }
    },
    {
      "id": "boundary_2",
      "type": "line",
      "source": "basemap",
      "source-layer": "boundaries",
      "filter": [
        "<=",
        "kind_detail",
        2
      ],
      "layout": {
        "line-cap": "round",
        "line-join": "round"
      },
      "paint": {
        "line-color": "rgb(6, 10, 16)",
        "line-opacity": [
          "interpolate", ["linear"], ["zoom"],
          0, 0.4,
          4, 0.72,
          10, 0.78
        ],
        "line-width": [
          "interpolate", ["linear"], ["zoom"],
          3, 0.82,
          5, 0.98,
          12, 1.9,
          20, 2.15
        ]
      }
    }
  ]
}
